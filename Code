/* -------- Ingest -------- */

function api_ingestFromFile(base64, mimeType, fileName) {
  const name = fileName || 'upload';

  // 重複取込防止: 同じ内容 (ハッシュ一致) なら 24h 以内はスキップ
  const cache = CacheService.getDocumentCache();
  const hash = Utilities.computeDigest(Utilities.DigestAlgorithm.SHA_256, base64).map(function (b) {
    return ('0' + (b & 0xff).toString(16)).slice(-2);
  }).join('');
  const cacheKey = 'ingested:' + hash;
  if (cache && cache.get(cacheKey)) {
    appendUploadLog({ source: name, method: 'アプリ', status: 'スキップ', rows: 0, error: '同一ファイルを直近に処理済' });
    return { added: 0, rows: [], skipped: true, reason: '同一ファイルを直近に処理済みです' };
  }

  try {
    const raw = extractStatementRows(base64, mimeType);
    const rows = _normalizeExtractedRows(raw);
    addStatementRows(rows, name);

    // Drive の「処理済」に元ファイルを保存 (経路統一+監査証跡)
    try {
      const folderId = getIngestFolderId();
      if (folderId) {
        const parent = DriveApp.getFolderById(folderId);
        const processed = _getOrCreateSubfolder(parent, PROCESSED_SUBFOLDER_NAME);
        const bytes = Utilities.base64Decode(base64);
        const blob = Utilities.newBlob(bytes, mimeType || 'application/octet-stream', name);
        processed.createFile(blob);
      }
    } catch (e) {
      console.warn('Drive保存失敗 (記帳は成功):', e);
    }
    if (cache) cache.put(cacheKey, '1', 24 * 60 * 60);  // 24h
    appendUploadLog({ source: name, method: 'アプリ', status: '成功', rows: rows.length });
    return { added: rows.length, rows: rows };
  } catch (e) {
    appendUploadLog({ source: name, method: 'アプリ', status: '失敗', error: String((e && e.message) || e) });
    throw e;
  }
}

