/* ===== 行フラグ計算 ===== */
function computeFlags(rows, openingSet) {
  var dupMap = {};
  rows.forEach(function(r) {
    var key = r.date + '|' + r.withdrawal + '|' + r.deposit + '|' + r.counterparty;
    dupMap[key] = (dupMap[key] || 0) + 1;
  });
  return rows.map(function(r) {
    var flags = { mismatch: false, duplicate: false };
    // OCRが残高を拾えた行のみ照合 (balance=0 は未記載として無視)
    if (openingSet && r.balance !== 0) {
      if (Math.abs(r.balance - r.running_balance) > 0.5) flags.mismatch = true;
    }
    var key = r.date + '|' + r.withdrawal + '|' + r.deposit + '|' + r.counterparty;
    if (dupMap[key] > 1) flags.duplicate = true;
    return flags;
  });
}

/* ===== 月別詳細 ===== */
function renderMonthlyDetail() {
  var data = STATE.detail;
  if (!data) return;
  document.getElementById('monthly-title').textContent = data.year_month + ' の取引明細';
  document.getElementById('opening-input').value = data.opening_balance == null ? '' : data.opening_balance;
  document.getElementById('opening-status').textContent = data.opening_set ? '' : '（未設定）';

  document.getElementById('k-opening').textContent = data.opening_set ? fmtYen(data.opening_balance) : '未設定';
  document.getElementById('k-deposit').textContent = fmtYen(data.deposit_total);
  document.getElementById('k-withdraw').textContent = fmtYen(data.withdrawal_total);
  document.getElementById('k-closing').textContent = data.opening_set ? fmtYen(data.closing_balance) : '—';
  document.getElementById('k-count').textContent = data.transaction_count + ' 件';

  var rows = data.rows.slice();
  var sk = STATE.sort.key, sd = STATE.sort.dir;
  rows.sort(function(a, b) {
    var va = a[sk], vb = b[sk];
    if (typeof va === 'number' && typeof vb === 'number') {
      return sd === 'asc' ? va - vb : vb - va;
    }
    va = String(va || ''); vb = String(vb || '');
    return sd === 'asc' ? (va < vb ? -1 : va > vb ? 1 : 0) : (va > vb ? -1 : va < vb ? 1 : 0);
  });

  if (STATE.filter) {
    var q = STATE.filter.toLowerCase();
    rows = rows.filter(function(r) {
      var text = [r.description, r.counterparty, r.notes, r.source, String(r.withdrawal), String(r.deposit)].join(' ').toLowerCase();
      return text.indexOf(q) >= 0;
    });
  }

  var flags = computeFlags(rows, data.opening_set);

  document.querySelectorAll('th.sortable').forEach(function(th) {
    th.classList.remove('asc','desc');
    if (th.dataset.sort === sk) th.classList.add(sd);
  });

  var mismatchCount = flags.filter(function(f){ return f.mismatch; }).length;
  var dupCount = flags.filter(function(f){ return f.duplicate; }).length;
  var note = document.getElementById('row-flags-note');
  var notes = [];
  if (mismatchCount) notes.push('<span class="badge warn">⚠ 残高不整合</span> ' + mismatchCount + ' 行');
  if (dupCount) notes.push('<span class="badge error">⚠ 重複疑い</span> ' + dupCount + ' 行');
  if (notes.length) { note.innerHTML = notes.join(' &nbsp; '); note.style.display = ''; }
  else note.style.display = 'none';

  var tb = document.querySelector('#stmt-tbl tbody');
  tb.innerHTML = '';
  if (!rows.length) {
    var tr = document.createElement('tr');
    var cell = document.createElement('td');
    cell.colSpan = 9; cell.style.textAlign = 'center'; cell.style.color = 'var(--muted)'; cell.style.padding = '24px';
    cell.textContent = STATE.filter ? '該当する行がありません。' : 'この月の取引はまだありません。';
    tr.appendChild(cell); tb.appendChild(tr);
    return;
  }
  rows.forEach(function(r, i) {
    var tr = document.createElement('tr');
    if (flags[i].mismatch) tr.classList.add('flag-mismatch');
    if (flags[i].duplicate) tr.classList.add('flag-duplicate');
    tr.appendChild(td(r.date || ''));

    var descTd = document.createElement('td');
    descTd.textContent = r.description || '';
    if (flags[i].mismatch || flags[i].duplicate) {
      var bd = el('span', { className: 'row-badges' });
      if (flags[i].mismatch) bd.appendChild(el('span', { className: 'badge warn', title: '記載 ' + fmt(r.balance) + ' / 計算 ' + fmt(r.running_balance) }, '残高⚠'));
      if (flags[i].duplicate) bd.appendChild(el('span', { className: 'badge error', title: '同日・同額・同相手先の行が複数あります' }, '重複'));
      descTd.appendChild(bd);
    }
    tr.appendChild(descTd);

    tr.appendChild(td(r.counterparty || ''));
    tr.appendChild(td(r.withdrawal ? fmt(r.withdrawal) : '', 'num'));
    tr.appendChild(td(r.deposit ? fmt(r.deposit) : '', 'num'));
    tr.appendChild(td(data.opening_set ? fmt(r.running_balance) : '', 'num'));
    tr.appendChild(td(r.notes || ''));
    tr.appendChild(td(r.source || ''));
    var actionTd = el('td', { className: 'row-actions' });
    var editBtn = el('button', { className: 'ghost small' }, '編集');
    editBtn.onclick = function() { openEditModal(r); };
    actionTd.appendChild(editBtn);
    tr.appendChild(actionTd);
    tb.appendChild(tr);
  });
}

