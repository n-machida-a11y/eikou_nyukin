      STATE.counterparties.forEach(function(c) {
        var tr = document.createElement('tr');
        tr.appendChild(td(c.name));
        tr.appendChild(td((c.aliases || []).join(' / ')));
        tr.appendChild(td(c.notes));
        var actionTd = document.createElement('td');
        var delBtn = el('button', { className: 'ghost small', style: 'color:var(--error)' }, '削除');
        delBtn.onclick = function() {
          if (!confirm('「' + c.name + '」を削除しますか?')) return;
          google.script.run
            .withSuccessHandler(function() { toast('削除しました'); refreshCounterparties(); })
            .withFailureHandler(function(e) { toast('削除失敗: ' + e.message); })
            .api_deleteCounterparty(c.name);
        };
        actionTd.appendChild(delBtn);
        tr.appendChild(actionTd);
        tb.appendChild(tr);
      });
      tbl.appendChild(tb); box.appendChild(tbl);
    })
    .api_listCounterparties();
}
document.getElementById('cp-add').onclick = function() {
  var v = document.getElementById('cp-new-name').value.trim();
  if (!v) { toast('相手先名を入力'); return; }
  google.script.run
    .withSuccessHandler(function() { document.getElementById('cp-new-name').value = ''; toast('追加しました'); refreshCounterparties(); })
    .withFailureHandler(function(e) { toast('追加失敗: ' + e.message); })
    .api_upsertCounterparty(v, [], '');
};
document.getElementById('cp-new-name').onkeydown = function(e) {
  if (e.key === 'Enter') document.getElementById('cp-add').click();
};

/* ===== Drive 設定 ===== */
function refreshDriveSettings() {
  google.script.run
    .withSuccessHandler(function(s) {
      var idInput = document.getElementById('drive-folder-id');
      if (idInput) idInput.value = s.id || '';
      var label = s.name
        ? '<span class="badge accent">取込先</span> ' + s.name
        : '<span class="badge warn">フォルダ未設定</span>';
      ['drive-current', 'drive-current-settings'].forEach(function(id) {
        var e = document.getElementById(id);
        if (e) e.innerHTML = label;
      });
      var link = document.getElementById('drive-open');
      if (link) {
        if (s.id) { link.href = 'https://drive.google.com/drive/folders/' + s.id; link.style.display = ''; }
        else { link.style.display = 'none'; }
      }
    })
    .api_getDriveFolder();
}
document.getElementById('drive-save').onclick = function() {
  var id = document.getElementById('drive-folder-id').value.trim();
  google.script.run
    .withSuccessHandler(function() { toast('保存しました'); refreshDriveSettings(); })
    .withFailureHandler(function(e) { toast('保存失敗: ' + e.message); })
    .api_setDriveFolder(id);
};

/* API状況 */
function refreshApiStatus() {
  google.script.run
    .withSuccessHandler(function(s) {
      var box = document.getElementById('api-status-block');
      box.innerHTML = s.hasApiKey
        ? '<span class="badge success">設定済み</span> Gemini API キーは設定されています。'
        : '<span class="badge error">未設定</span> キーが未設定のため、OCR機能は利用できません。';
    })
    .api_getApiKeyStatus();
}

/* ===== Drive 取込実行 ===== */
function renderDriveResults(res) {
  var box = document.getElementById('drive-results');
  box.innerHTML = '';
  if (!res) return;
  box.appendChild(el('div', { className: 'muted', style: 'margin:12px 0 8px' },
    'フォルダ「' + (res.folderName || '') + '」— ' + res.scanned + ' ファイル / ' + res.addedRows + ' 行記帳'));
  if (!res.results || !res.results.length) {
    box.appendChild(el('div', { className: 'muted' }, '対象ファイルがありませんでした。'));
    return;
  }
  var tbl = el('table'), thead = el('thead'), thr = document.createElement('tr');
  ['ファイル','結果','行数','詳細'].forEach(function(h){ thr.appendChild(el('th', null, h)); });
  thead.appendChild(thr); tbl.appendChild(thead);
  var tb = el('tbody');
  res.results.forEach(function(r){
    var tr = document.createElement('tr');
    tr.appendChild(el('td', null, r.file));
    var st = document.createElement('td');
    st.appendChild(el('span', { className: 'badge ' + (r.ok ? 'success' : 'error') }, r.ok ? '成功' : '失敗'));
    tr.appendChild(st);
    tr.appendChild(el('td', { className: 'num' }, r.ok ? String(r.added||0) : '-'));
    tr.appendChild(el('td', { className: 'muted' }, r.ok ? '' : (r.error || '')));
    tb.appendChild(tr);
  });
  tbl.appendChild(tb); box.appendChild(tbl);
}
document.getElementById('drive-run').onclick = function() {
  var btn = this; btn.disabled = true;
  document.getElementById('drive-status').innerHTML = '<span class="spinner"></span> 取込中…';
  google.script.run
    .withSuccessHandler(function(res) {
      btn.disabled = false;
      var statusHtml = '<span class="badge success">完了</span> ' +
        res.processed + '/' + res.scanned + ' ファイル処理 / ' + res.addedRows + ' 行';
      if (res.remaining) {
        statusHtml += ' <span class="badge warn">⚠ ' + res.remaining + ' ファイル残り</span> (時間切れ — もう一度「取込」を押してください)';
      }
      document.getElementById('drive-status').innerHTML = statusHtml;
      renderDriveResults(res);
      refreshSummaries();
      refreshFailedFiles();
    })
    .withFailureHandler(function(e) {
      btn.disabled = false;
      document.getElementById('drive-status').innerHTML = '<span class="badge error">エラー</span> ' + e.message;
    })
    .api_ingestFromDriveFolder('');  // 既定フォルダを使う
};

/* ===== Upload ===== */
var SELECTED = [];
function refreshSelected() {
  var el2 = document.getElementById('selected-files');
  document.getElementById('upload-run').disabled = SELECTED.length === 0;
  if (!SELECTED.length) { el2.textContent = '未選択'; return; }
  el2.textContent = SELECTED.length + ' ファイル選択';
}
document.getElementById('file-btn').onclick = function() { document.getElementById('file-input').click(); };
document.getElementById('drop-zone').onclick = function(e) {
  if (e.target.closest('#file-btn')) return;
  document.getElementById('file-input').click();
};
document.getElementById('file-input').onchange = function(e) {
  SELECTED = Array.prototype.slice.call(e.target.files);
  refreshSelected();
};
var dz = document.getElementById('drop-zone');
dz.ondragover = function(e) { e.preventDefault(); dz.classList.add('drag-over'); };
dz.ondragleave = function() { dz.classList.remove('drag-over'); };
dz.ondrop = function(e) {
  e.preventDefault(); dz.classList.remove('drag-over');
  SELECTED = Array.prototype.slice.call(e.dataTransfer.files).filter(function(f){
    return /^image\//.test(f.type) || f.type === 'application/pdf' || /\.pdf$/i.test(f.name);
  });
  refreshSelected();
};
document.getElementById('upload-run').onclick = function() {
  if (!SELECTED.length) return;
  var btn = this; btn.disabled = true;
  var statusEl = document.getElementById('upload-status');
  var totalRows = 0, idx = 0;
  function next() {
    if (idx >= SELECTED.length) {
      btn.disabled = false;
      statusEl.innerHTML = '<span class="badge success">完了</span> ' + totalRows + ' 行を記帳';
      toast(totalRows + ' 行を記帳しました');
      SELECTED = []; refreshSelected();
      document.getElementById('file-input').value = '';
      refreshSummaries();
      return;
    }
    var f = SELECTED[idx++];
    statusEl.innerHTML = '<span class="spinner"></span> ' + idx + '/' + SELECTED.length + ' 読取り中… (' + f.name + ')';
    var r = new FileReader();
    r.onload = function() {
      var base64 = r.result.split(',')[1];
      var mime = f.type || (f.name.toLowerCase().endsWith('.pdf') ? 'application/pdf' : 'image/jpeg');
      google.script.run
        .withSuccessHandler(function(res) {
          totalRows += res.added || 0;
          if (res.skipped) {
            statusEl.textContent = idx + '/' + SELECTED.length + ' スキップ (' + f.name + '): 同一ファイルを直近に処理済み';
          } else {
            statusEl.textContent = idx + '/' + SELECTED.length + ' 完了 — +' + res.added + ' 行';
          }
          next();
        })
        .withFailureHandler(function(e) {
          statusEl.innerHTML = '<span class="badge error">エラー</span> (' + f.name + '): ' + e.message;
          btn.disabled = false;
        })
        .api_ingestFromFile(base64, mime, f.name);
    };
    r.readAsDataURL(f);
  }
  next();
};

/* キーボードショートカット */
document.addEventListener('keydown', function(e) {
  if (!document.getElementById('edit-modal').classList.contains('show')) return;
  if (e.key === 'Escape') closeEditModal();
  if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) document.getElementById('e-save').click();
});

bootstrap();
</script>
