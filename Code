<script>
function toast(msg) {
  var t = document.getElementById('toast');
  t.textContent = msg; t.classList.add('show');
  setTimeout(function(){ t.classList.remove('show'); }, 2500);
}
function fmt(n) { return (Number(n) || 0).toLocaleString(); }
function fmtYen(n) { return n == null ? '—' : '¥' + fmt(n); }
function el(tag, opts, text) {
  var e = document.createElement(tag);
  if (opts && opts.className) e.className = opts.className;
  if (opts && opts.style) e.setAttribute('style', opts.style);
  if (opts && opts.title) e.title = opts.title;
  if (text != null) e.textContent = String(text);
  return e;
}
function td(text, cls) {
  var e = document.createElement('td');
  if (cls) e.className = cls;
  e.textContent = text == null ? '' : String(text);
  return e;
}

/* ===== state ===== */
var STATE = {
  activeYm: null,
  summaries: [],
  detail: null,
